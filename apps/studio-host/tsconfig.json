{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "paths": {
      "@wasm/rhwp.js": ["./vendor/rhwp-core/rhwp.d.ts"],
      "canvaskit-wasm": ["./node_modules/canvaskit-wasm"],
      "canvaskit-wasm/*": ["./node_modules/canvaskit-wasm/*"],
      "@upstream/*": ["../../third_party/rhwp/rhwp-studio/src/*"],
      "@/*": ["./src/*", "../../third_party/rhwp/rhwp-studio/src/*"]
    }
  },
  "include": ["src"]
}
