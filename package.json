{
  "name": "hop",
  "version": "0.2.0",
  "private": true,
  "description": "HOP is Open HWP",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build:studio": "pnpm --filter @golbin/hop-studio-host build",
    "build:quicklook:macos": "node scripts/build-quicklook-macos.mjs",
    "build:before-tauri": "pnpm run build:studio && pnpm run build:quicklook:macos",
    "build:desktop": "pnpm --filter hop-desktop build",
    "tauri": "pnpm --filter hop-desktop tauri",
    "test": "pnpm run test:upstream && pnpm run test:studio && pnpm run test:desktop && pnpm run test:quicklook:macos",
    "test:upstream": "node --test tests/update-upstream.test.mjs tests/rhwp-baseline.test.mjs",
    "test:studio": "pnpm --filter @golbin/hop-studio-host test",
    "test:desktop": "cd apps/desktop/src-tauri && cargo test",
    "test:quicklook:macos": "node scripts/test-quicklook-macos.mjs",
    "clippy:desktop": "cd apps/desktop/src-tauri && cargo clippy -- -D warnings"
  }
}
